---
import profile from '../data/profile.json';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const getUrl = (url: string) => url.startsWith('http') ? url : `${base}${url.replace(/^\//, '')}`;
---

<section class="hero-section" id="hero">
  <div class="hero-bg" style={`background-image: url(${getUrl(profile.coverUrl)});`}></div>
  <div class="hero-overlay"></div>
  
  <div class="container hero-container">
    <div class="hero-content">
      <div class="avatar-wrapper">
        <img src={getUrl(profile.avatarUrl)} alt={profile.name} class="avatar-img" />
      </div>
      
      <h1 class="hero-title">{profile.name}</h1>
      <p class="hero-role gradient-text">{profile.role}</p>
      
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Contrate-me</a>
        <a href={getUrl(profile.cvUrl)} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download CV
        </a>
      </div>

      <div class="social-links">
        {profile.socials.map(social => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-btn" title={social.platform}>
            {social.platform}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    filter: blur(4px) brightness(0.4);
    transform: scale(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 29, 0.4), var(--bg-dark));
  }

  .hero-container {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .avatar-wrapper {
    width: 150px;
    height: 150px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    padding: 4px;
    background: var(--primary-gradient);
    box-shadow: var(--shadow-glow);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-btn {
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--bg-card-border);
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .social-btn:hover {
    color: #fff;
    background: rgba(59, 130, 246, 0.2);
    border-color: var(--primary);
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.25rem; }
    .hero-role { font-size: 1.15rem; }
  }
</style>
