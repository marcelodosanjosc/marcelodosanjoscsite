---
import projects from '../data/projects.json';
---

<section class="section" id="projects">
  <div class="container">
    <h2 class="section-title">Portfólio de Projetos</h2>

    <div class="projects-grid">
      {projects.map(project => (
        <div class="glass-panel project-card">
          <div class="project-img-wrapper" data-img={project.imageUrl} data-title={project.title}>
            <!-- Ambient blurred background fill -->
            <img src={project.imageUrl} alt="" class="project-img-bg" aria-hidden="true" />
            
            <!-- Main uncropped image -->
            <img src={project.imageUrl} alt={project.title} class="project-img-main" loading="lazy" />
            
            <span class="project-badge">{project.category}</span>
            <div class="zoom-hint">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              Clique para ampliar
            </div>
          </div>

          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>

            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>

            <div class="project-links">
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="btn-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Ver Demo
                </a>
              )}
              {project.githubUrl && (
                <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  GitHub
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Lightbox Modal -->
    <dialog id="lightbox-dialog" class="lightbox-modal">
      <div class="lightbox-content">
        <button id="lightbox-close" class="lightbox-close-btn" aria-label="Fechar modal">&times;</button>
        <img id="lightbox-img" src="" alt="" class="lightbox-full-img" />
        <h4 id="lightbox-caption" class="lightbox-caption"></h4>
      </div>
    </dialog>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const dialog = document.getElementById('lightbox-dialog');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('lightbox-close');

    document.querySelectorAll('.project-img-wrapper').forEach(wrapper => {
      wrapper.addEventListener('click', () => {
        const imgSrc = wrapper.getAttribute('data-img');
        const title = wrapper.getAttribute('data-title');
        if (imgSrc && dialog && lightboxImg && lightboxCaption) {
          lightboxImg.src = imgSrc;
          lightboxCaption.textContent = title || '';
          dialog.showModal();
        }
      });
    });

    closeBtn?.addEventListener('click', () => {
      dialog?.close();
    });

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close();
      }
    });
  });
</script>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .project-img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #060913;
    cursor: pointer;
  }

  .project-img-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(16px) opacity(0.35);
    transform: scale(1.1);
  }

  .project-img-main {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
    transition: var(--transition-normal);
  }

  .project-img-wrapper:hover .project-img-main {
    transform: scale(1.03);
  }

  .zoom-hint {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: rgba(10, 15, 29, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--bg-card-border);
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0;
    transition: var(--transition-fast);
  }

  .project-img-wrapper:hover .zoom-hint {
    opacity: 1;
  }

  .project-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 3;
    padding: 0.25rem 0.75rem;
    background: rgba(10, 15, 29, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--bg-card-border);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--primary);
  }

  .project-content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .project-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.05);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-main);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: var(--transition-fast);
  }

  .btn-link:hover {
    color: var(--primary);
  }

  /* Lightbox Dialog */
  .lightbox-modal {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 90vw;
    max-height: 90vh;
    margin: auto;
  }

  .lightbox-modal::backdrop {
    background: rgba(5, 8, 18, 0.85);
    backdrop-filter: blur(12px);
  }

  .lightbox-content {
    position: relative;
    background: var(--bg-dark);
    border: 1px solid var(--bg-card-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close-btn {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.75rem;
    cursor: pointer;
    line-height: 1;
    transition: var(--transition-fast);
  }

  .lightbox-close-btn:hover {
    color: #fff;
  }

  .lightbox-full-img {
    max-width: 80vw;
    max-height: 75vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .lightbox-caption {
    margin-top: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-main);
  }
</style>
