---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Marcelo Caldas | Desenvolvedor Full-Stack & Analista de Sistemas",
  description = "Portfólio profissional de Marcelo Caldas - Bacharel em Sistemas de Informação, Desenvolvedor Full-Stack e Analista de Sistemas."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Marcelo dos Anjos Caldas" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://marcelocaldasdevops.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://marcelocaldasdevops.com/img/Foto-perfil-novo.jpeg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://marcelocaldasdevops.com/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://marcelocaldasdevops.com/img/Foto-perfil-novo.jpeg" />

    <!-- GA4 Tag -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MEASUREMENT_ID"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MEASUREMENT_ID');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
